doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    meta(http-equiv="X-UA-Compatible" content="ie=edge")

    title Travel editor

    style.
      #app-loader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.92);
      }
      #app-loader .app-loader__spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #dee2e6;
        border-top-color: #868e96;
        border-radius: 50%;
        animation: app-loader-spin 0.8s linear infinite;
      }
      #app-loader .app-loader__text {
        margin-top: 12px;
        font-size: 14px;
        font-weight: 600;
        color: #495057;
      }
      #app-loader .app-loader__content {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      @keyframes app-loader-spin {
        to { transform: rotate(360deg); }
      }

    body
      div#app-loader.app-loader
        div.app-loader__content
          div.app-loader__spinner
          p.app-loader__text Загрузка карты...

      // map containers
      div#map.map

      // map zoomer
      div#map-zoomer
        button.btn.btn-light.zoom_up(type="button") +
        button.btn.btn-light.zoom_down(type="button") -

      // map context menu
      div#context-menu
        div.card

      // map control panel
      div#control-panel
        div#map-hint.map-hint
          span.map-hint__text Используйте правый клик по карте, чтобы открыть меню с действиями
        div.card
          div.card-body
            h5.card-title Travel editor

      include src/editors/country-editor/template.pug
      include src/editors/country-editor/controls/context.menu.pug
      include src/editors/marker-editor/controls/context.menu.pug
      include src/editors/marker-editor/template.pug
      //move to controll panel aftewords
      div.marker-overlay-container
        span.marker-label-overlay.badge.badge-light
